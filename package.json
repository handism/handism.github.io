{
  "name": "next-techblog",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/download-fonts.js && next dev",
    "build": "node scripts/download-fonts.js && next build",
    "start": "serve out",
    "lint": "eslint",
    "test:unit": "vitest run",
    "test:vrt": "playwright test",
    "test:vrt:update": "playwright test --update-snapshots",
    "analyze": "ANALYZE=true next build",
    "type-check": "tsc --noEmit",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@shikijs/rehype": "^3.22.0",
    "fuse.js": "^7.1.0",
    "gray-matter": "^4.0.3",
    "image-size": "^2.0.2",
    "js-yaml": "^4.1.0",
    "jszip": "^3.10.1",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.563.0",
    "mermaid": "^11.15.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-easy-crop": "^5.5.6",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-cjk-friendly": "^2.3.1",
    "remark-cjk-friendly-gfm-strikethrough": "^2.3.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.1",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "lint-staged": "16",
    "postcss": "^8.4.32",
    "prettier": "^3.8.1",
    "serve": "^14.2.6",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  },
  "simple-git-hooks": {
    "pre-commit": "bunx lint-staged && bun run type-check"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  }
}
