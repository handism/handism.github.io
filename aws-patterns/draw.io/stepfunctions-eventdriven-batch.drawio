<mxfile host="app.diagrams.net">
  <diagram name="Event-Driven Batch Architecture" id="stepfunctions-eventdriven-batch">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" background="#ffffff">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- AWS Cloud Container -->
        <mxCell id="aws-cloud" value="AWS Cloud" style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud;strokeColor=#AAB7B8;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="1240" height="740" as="geometry"/>
        </mxCell>
        
        <!-- Region Container -->
        <mxCell id="region" value="Region: ap-northeast-1" style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=0;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_region;strokeColor=#00A4A6;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#147EBA;dashed=1;" vertex="1" parent="aws-cloud">
          <mxGeometry x="40" y="40" width="1160" height="660" as="geometry"/>
        </mxCell>
        
        <!-- User/Admin client -->
        <mxCell id="user" value="User / System" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3D;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.user;" vertex="1" parent="1">
          <mxGeometry x="20" y="200" width="40" height="39" as="geometry"/>
        </mxCell>
        
        <!-- S3 Bucket -->
        <mxCell id="s3" value="S3 Bucket&#xa;(Upload Documents)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3_bucket;" vertex="1" parent="region">
          <mxGeometry x="120" y="80" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- EventBridge -->
        <mxCell id="eventbridge" value="EventBridge&#xa;(S3 Event Rule)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.eventbridge;" vertex="1" parent="region">
          <mxGeometry x="120" y="280" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- S3 Trigger Lambda -->
        <mxCell id="lambda-trigger" value="Lambda&#xa;(S3 Event Handler)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda_function;" vertex="1" parent="region">
          <mxGeometry x="360" y="280" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Step Functions State Machine -->
        <mxCell id="step-functions" value="Step Functions&#xa;(Batch Orchestrator)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.step_functions;" vertex="1" parent="region">
          <mxGeometry x="600" y="280" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Task Processor Lambda -->
        <mxCell id="lambda-processor" value="Lambda&#xa;(File Processor)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda_function;" vertex="1" parent="region">
          <mxGeometry x="840" y="280" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Job Status Table (DynamoDB) -->
        <mxCell id="dynamodb" value="DynamoDB&#xa;(Job Status Table)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;" vertex="1" parent="region">
          <mxGeometry x="600" y="80" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Dead Letter Queue (SQS) -->
        <mxCell id="sqs-dlq" value="SQS Queue&#xa;(Job DLQ)" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.sqs;" vertex="1" parent="region">
          <mxGeometry x="600" y="480" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- CloudWatch Logs -->
        <mxCell id="cloudwatch" value="CloudWatch&#xa;Logs" style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor=#759C3E;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;" vertex="1" parent="region">
          <mxGeometry x="840" y="480" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Connections -->
        <!-- User upload to S3 -->
        <mxCell id="conn1" value="Upload File" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="1" source="user" target="s3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- S3 notifies EventBridge -->
        <mxCell id="conn2" value="S3 Event" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="s3" target="eventbridge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- EventBridge triggers Trigger Lambda -->
        <mxCell id="conn3" value="Trigger" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="eventbridge" target="lambda-trigger">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Trigger Lambda starts State Machine -->
        <mxCell id="conn4" value="Start Workflow" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="lambda-trigger" target="step-functions">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- State Machine updates DynamoDB -->
        <mxCell id="conn5" value="Update Status" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#C925D1;fontSize=11;fontColor=#C925D1;" edge="1" parent="region" source="step-functions" target="dynamodb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- State Machine invokes Processor Lambda -->
        <mxCell id="conn6" value="Execute Tasks" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="step-functions" target="lambda-processor">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Processor Lambda gets data from S3 -->
        <mxCell id="conn7" value="Read File" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="lambda-processor" target="s3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="880" y="200"/>
              <mxPoint x="230" y="200"/>
              <mxPoint x="230" y="120"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- State Machine routes errors to DLQ -->
        <mxCell id="conn8" value="Handle Failure" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#DD344C;fontSize=11;fontColor=#DD344C;" edge="1" parent="region" source="step-functions" target="sqs-dlq">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Functions output logs to CloudWatch -->
        <mxCell id="conn9" value="Write Logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=1;strokeColor=#545B64;dashed=1;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="lambda-processor" target="cloudwatch">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Title -->
        <mxCell id="title" value="Event-Driven Serverless Batch Processing Workflow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="80" y="20" width="600" height="40" as="geometry"/>
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F3F4;strokeColor=#AAB7B8;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1000" y="20" width="320" height="100" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend-title" value="Legend" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1010" y="25" width="100" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend1" value="Solid line: Core data & orchestrate flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#545B64;" vertex="1" parent="1">
          <mxGeometry x="1010" y="50" width="220" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend2" value="Red line: Error route / DLQ pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#DD344C;" vertex="1" parent="1">
          <mxGeometry x="1010" y="70" width="200" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend3" value="Dashed line: Logging & Monitoring" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#545B64;" vertex="1" parent="1">
          <mxGeometry x="1010" y="90" width="250" height="20" as="geometry"/>
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
