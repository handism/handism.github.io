        <!-- Highlights Box -->
        <mxCell id="note-highlights" value="Security &amp; Governance Highlights:&#xa;- Centralized access control via Lake Formation&#xa;- Server-side encryption using KMS CMK&#xa;- Raw, Processed, and Query Results isolation&#xa;- Glue Crawler handles schema inference&#xa;- Athena analyst roles restricted to target workgroup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="region">
