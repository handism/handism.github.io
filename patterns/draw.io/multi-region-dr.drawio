        </mxCell>

        <!-- Note of DR Strategy -->
        <mxCell id="note-dr" value="Disaster Recovery Strategy:&#xa;- Route 53 active-passive DNS failover&#xa;- RPO: &lt; 15 mins for S3, &lt; 1 sec for Aurora&#xa;- RTO: Minutes (requires database promotion)&#xa;- Cross-region KMS key translation supported" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FF;strokeColor=#0066CC;align=left;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="aws-cloud">
