        <!-- Shield protection to CloudFront & ALB -->
        <mxCell id="conn-shield-cf" edge="1" parent="1" source="shield" target="cloudfront" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#545B64;fontSize=11;dashed=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- WAF Regional to Logs -->
        <mxCell id="conn-waf-logs" edge="1" parent="1" source="waf-regional" target="cw-logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#545B64;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Alarms monitoring WAF Regional -->
        <mxCell id="conn-alarm-waf" edge="1" parent="1" source="cw-alarms" target="waf-regional" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#545B64;fontSize=11;dashed=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Security Features Note -->
        <mxCell id="sec-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D79B00;align=left;verticalAlign=top;fontStyle=1;fontSize=11;" value="Security Hardening &amp; Rules:&#xa;• Common Rule Set (CRS): Protects against OWASP Top 10 vulnerabilities&#xa;• Known Bad Inputs: Detects malicious payloads &amp; vulnerability scanners&#xa;• SQL Injection (SQLi): Inspects query strings and bodies for SQLi patterns&#xa;• Amazon IP Reputation: Blocks requests from known bots/malicious hosts&#xa;• Rate Limiting: Blocks IPs exceeding 2,000 requests per 5 minutes&#xa;• IP Set Control: Explicit blocklist/allowlist configuration" vertex="1">
          <mxGeometry height="140" width="380" x="280" y="410" as="geometry" />
        </mxCell>

        <!-- Monitoring Features Note -->
        <mxCell id="mon-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E6F2FF;strokeColor=#0066CC;align=left;verticalAlign=top;fontStyle=1;fontSize=11;" value="Monitoring &amp; Alarms:&#xa;• WAFBlockedRequestsAlarm: Triggers if overall WAF blocks &gt; 100 reqs in 5m&#xa;• WAFRateLimitAlarm: Triggers if Rate Limiting blocks &gt; 50 reqs in 5m&#xa;• WAF Logs: Complete request logging (including matched rule) retained for 90 days" vertex="1">
          <mxGeometry height="140" width="320" x="680" y="410" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
