          <mxGeometry height="60" width="60" x="30" y="270" as="geometry" />
        </mxCell>

        <!-- CloudFront Distribution -->
        <mxCell id="cloudfront" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#8C4FFF;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.cloudfront;" value="CloudFront Distribution&#xa;(Global Edge)" vertex="1">
