        <!-- Highlights Note -->
        <mxCell id="note-highlights" value="Key Configurations:&#xa;- Fargate serverless node execution&#xa;- VPC Multi-AZ setup with NAT Gateway&#xa;- AWS Load Balancer Controller manages ALB Ingress&#xa;- IAM Roles for Service Accounts (IRSA) for least privilege&#xa;- Private subnets restrict direct external pod access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="region">
