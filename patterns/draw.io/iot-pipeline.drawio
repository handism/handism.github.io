        <mxCell id="edge-kinesis-lambda" value="Event Source Map&#xa;(Batch: 100)" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=10;" edge="1" parent="region" source="kinesis" target="lambda-telemetry">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Telemetry Lambda to DynamoDB -->
        <mxCell id="edge-lambda-ddb" value="PutItem" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=10;exitX=1;exitY=0.25;entryX=0;entryY=0.25;" edge="1" parent="region" source="lambda-telemetry" target="dynamodb">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Telemetry Lambda to S3 -->
        <mxCell id="edge-lambda-s3" value="PutObject" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=10;exitX=1;exitY=0.75;entryX=0;entryY=0.25;" edge="1" parent="region" source="lambda-telemetry" target="s3-bucket">
