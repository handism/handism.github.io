          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Telemetry Rule to Kinesis -->
        <mxCell id="edge-iot-kinesis" value="Telemetry Rule&#xa;devices/+/telemetry" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=10;exitX=1;exitY=0.25;entryX=0;entryY=0.5;" edge="1" parent="region" source="iot-core" target="kinesis">
          <mxGeometry relative="1" as="geometry"/>
