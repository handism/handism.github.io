        <!-- Connections -->
        <!-- User to CloudFront -->
        <mxCell id="conn-user-cf" edge="1" parent="1" source="user" target="cloudfront" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;">
          <mxGeometry relative="1" as="geometry" />
