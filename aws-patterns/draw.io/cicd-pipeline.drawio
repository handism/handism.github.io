        <!-- CloudWatch Alarm to Pipeline -->
        <mxCell id="conn-alarm-pipeline" edge="1" parent="1" source="cw-alarm" target="codepipeline" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#545B64;fontSize=11;dashed=1;">
