        <!-- Best Practices Note -->
        <mxCell id="bp-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;align=left;verticalAlign=top;fontStyle=1;fontSize=11;" value="CI/CD Best Practices:&#xa;• Security: ECR KMS encryption &amp; Image scanning on push&#xa;• Lifecycle: Automatically expire old ECR images (Keep last 20)&#xa;• Privileged Mode: Enabled in CodeBuild to build Docker images&#xa;• Least Privilege: Isolated IAM roles for CodePipeline &amp; CodeBuild&#xa;• Failure Detection: CloudWatch Alarm triggers on pipeline failure" vertex="1">
