<mxfile host="app.diagrams.net">
  <diagram name="MCP Server Architecture" id="mcp-server">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" background="#ffffff">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- AWS Cloud Container -->
        <mxCell id="aws-cloud" value="AWS Cloud" style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=14;fontStyle=1;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_aws_cloud;strokeColor=#AAB7B8;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#232F3E;dashed=0;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="1240" height="740" as="geometry"/>
        </mxCell>
        
        <!-- Region Container -->
        <mxCell id="region" value="Region: ap-northeast-1" style="sketch=0;outlineConnect=0;gradientColor=none;html=1;whiteSpace=wrap;fontSize=12;fontStyle=0;container=1;pointerEvents=0;collapsible=0;recursiveResize=0;shape=mxgraph.aws4.group;grIcon=mxgraph.aws4.group_region;strokeColor=#00A4A6;fillColor=none;verticalAlign=top;align=left;spacingLeft=30;fontColor=#147EBA;dashed=1;" vertex="1" parent="aws-cloud">
          <mxGeometry x="40" y="40" width="1160" height="660" as="geometry"/>
        </mxCell>
        
        <!-- Client -->
        <mxCell id="client" value="Client" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;fillColor=#232F3D;strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;pointerEvents=1;shape=mxgraph.aws4.client;" vertex="1" parent="1">
          <mxGeometry x="20" y="380" width="40" height="39" as="geometry"/>
        </mxCell>
        
        <!-- API Gateway -->
        <mxCell id="api-gateway" value="API Gateway&#xa;(REST API)" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.api_gateway;" vertex="1" parent="region">
          <mxGeometry x="120" y="280" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Lambda Function -->
        <mxCell id="lambda" value="Lambda&#xa;(MCP Processor)" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#ED7100;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.lambda;" vertex="1" parent="region">
          <mxGeometry x="400" y="280" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- DynamoDB -->
        <mxCell id="dynamodb" value="DynamoDB&#xa;(Session Table)" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#C925D1;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.dynamodb;" vertex="1" parent="region">
          <mxGeometry x="680" y="180" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- S3 Bucket -->
        <mxCell id="s3" value="S3&#xa;(Model Artifacts)" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#7AA116;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.s3;" vertex="1" parent="region">
          <mxGeometry x="680" y="380" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- CloudWatch Logs -->
        <mxCell id="cloudwatch" value="CloudWatch&#xa;Logs" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.cloudwatch_2;" vertex="1" parent="region">
          <mxGeometry x="400" y="500" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- IAM Role -->
        <mxCell id="iam" value="IAM Role" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#DD344C;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.iam_role;" vertex="1" parent="region">
          <mxGeometry x="400" y="100" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- CloudWatch Alarm -->
        <mxCell id="alarm" value="CloudWatch&#xa;Alarm" style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor=#E7157B;strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.alarm;" vertex="1" parent="region">
          <mxGeometry x="680" y="500" width="80" height="80" as="geometry"/>
        </mxCell>
        
        <!-- Connections -->
        <!-- Client to API Gateway -->
        <mxCell id="conn1" value="HTTPS" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="1" source="client" target="api-gateway">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="100" y="400"/>
              <mxPoint x="100" y="400"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- API Gateway to Lambda -->
        <mxCell id="conn2" value="Invoke" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="api-gateway" target="lambda">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Lambda to DynamoDB -->
        <mxCell id="conn3" value="Read/Write&#xa;Sessions" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="lambda" target="dynamodb">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="280"/>
              <mxPoint x="580" y="220"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Lambda to S3 -->
        <mxCell id="conn4" value="Get/Put&#xa;Artifacts" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;" edge="1" parent="region" source="lambda" target="s3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="580" y="360"/>
              <mxPoint x="580" y="420"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Lambda to CloudWatch -->
        <mxCell id="conn5" value="Logs" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;dashed=1;" edge="1" parent="region" source="lambda" target="cloudwatch">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- IAM to Lambda -->
        <mxCell id="conn6" value="Assumes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;dashed=1;" edge="1" parent="region" source="iam" target="lambda">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- Lambda to Alarm -->
        <mxCell id="conn7" value="Metrics" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=2;strokeColor=#545B64;fontSize=11;fontColor=#545B64;dashed=1;" edge="1" parent="region" source="lambda" target="alarm">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="540" y="320"/>
              <mxPoint x="540" y="540"/>
            </Array>
          </mxGeometry>
        </mxCell>
        
        <!-- Title -->
        <mxCell id="title" value="MCP Server Architecture on AWS" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="80" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        
        <!-- Legend -->
        <mxCell id="legend-box" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2F3F4;strokeColor=#AAB7B8;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1000" y="20" width="320" height="100" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend-title" value="Legend" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#232F3E;" vertex="1" parent="1">
          <mxGeometry x="1010" y="25" width="100" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend1" value="Solid line: Data flow" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#545B64;" vertex="1" parent="1">
          <mxGeometry x="1010" y="50" width="150" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend2" value="Dashed line: Monitoring/IAM" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#545B64;" vertex="1" parent="1">
          <mxGeometry x="1010" y="70" width="200" height="20" as="geometry"/>
        </mxCell>
        
        <mxCell id="legend3" value="ARM64 Lambda for cost optimization" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#545B64;" vertex="1" parent="1">
          <mxGeometry x="1010" y="90" width="250" height="20" as="geometry"/>
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
