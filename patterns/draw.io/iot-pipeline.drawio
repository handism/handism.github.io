        </mxCell>

        <!-- Telemetry Lambda to DLQ -->
        <mxCell id="edge-lambda-dlq" value="On Failure" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#DD344C;dashed=1;fontSize=10;exitX=0.5;exitY=0;entryX=0.5;entryY=1;" edge="1" parent="region" source="lambda-telemetry" target="sqs-dlq">
