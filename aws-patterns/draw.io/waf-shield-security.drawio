        </mxCell>

        <!-- WAF CloudFront Association -->
        <mxCell id="conn-waf-cf" edge="1" parent="1" source="waf-cloudfront" target="cloudfront" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#545B64;fontSize=11;dashed=1;">
          <mxGeometry relative="1" as="geometry" />
