        <!-- Highlights Note -->
        <mxCell id="note-highlights" value="Key Configurations:&#xa;- Real-time ingest via Kinesis Data Streams&#xa;- Critical alert fast-path direct to Lambda&#xa;- Encrypted storage (KMS) for all data stores&#xa;- Automatic retry &amp; error containment (SQS DLQ)&#xa;- 30 days TTL on state table, lifecycle on S3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D79B00;align=left;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="region">
