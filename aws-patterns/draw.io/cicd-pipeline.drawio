        <!-- CodeBuild to S3 Bucket (Read/Write Artifacts) -->
        <mxCell id="conn-build-s3" edge="1" parent="1" source="codebuild" target="s3-bucket" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;strokeWidth=1;strokeColor=#545B64;fontSize=11;dashed=1;">
